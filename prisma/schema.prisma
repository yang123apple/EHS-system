generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id              String             @id @default(cuid())
  code            String             @unique @default(cuid())
  name            String
  contractNo      String?
  location        String
  startDate       DateTime
  endDate         DateTime
  // ⚠️ DEPRECATED: 使用 requestorDept 替代
  requestDept     String
  // ⚠️ DEPRECATED: 使用 requestorHead 替代
  requestHead     String
  // ⚠️ DEPRECATED: 使用 requestorContact 替代
  requestContact  String
  // ⚠️ DEPRECATED: 使用 supervisorDept 替代
  mgmtDept        String?
  // ⚠️ DEPRECATED: 使用 supervisorHead 替代
  mgmtHead        String?
  // ⚠️ DEPRECATED: 使用 supervisorContact 替代
  mgmtContact     String?
  // ⚠️ DEPRECATED: 使用 contractorName 替代
  supplierName    String
  // ⚠️ DEPRECATED: 使用 contractorHead 替代
  supplierHead    String
  // ⚠️ DEPRECATED: 使用 contractorContact 替代
  supplierContact String

  // ✅ 新字段：申请方（推荐使用）
  requestorDept    String? // 申请部门
  requestorHead    String? // 申请人
  requestorContact String? // 申请人联系方式

  // ✅ 新字段：监管方（推荐使用）
  supervisorDept    String? // 监管部门
  supervisorHead    String? // 监管负责人
  supervisorContact String? // 监管联系方式

  // ✅ 新字段：承包商（推荐使用）
  contractorName    String? // 承包商名称
  contractorHead    String? // 承包商负责人
  contractorContact String? // 承包商联系方式

  attachments     String?
  deletedAt       DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  permits         WorkPermitRecord[]
}

model WorkPermitTemplate {
  id               String             @id @default(cuid())
  name             String
  type             String
  structureJson    String
  workflowConfig   String?
  parsedFields     String?
  level            String             @default("primary")
  sectionBindings  String?
  orientation      String             @default("portrait")
  mobileFormConfig String?
  isLocked         Boolean            @default(false)
  // 🟢 动态记录型模板（如：气体检测、巡检记录）
  // 允许在父表单审批通过后，以“追加记录”的方式持续写入
  isDynamicLog     Boolean            @default(false)
  createdAt        DateTime           @default(now())
  records          WorkPermitRecord[]
}

model WorkPermitRecord {
  id                String             @id @default(cuid())
  code              String?            @unique
  projectId         String
  project           Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  templateId        String
  template          WorkPermitTemplate @relation(fields: [templateId], references: [id])
  dataJson          String
  status            String             @default("draft")
  currentStep       Int                @default(0)
  approvalLogs      String?
  attachments       String?
  parsedFieldValues String?
  candidateHandlers String? // 🟢 或签/会签模式：候选审批人列表（JSON格式）
  approvalMode      String? // 🟢 当前步骤的审批模式（OR=或签，AND=会签）
  createdAt         DateTime           @default(now())

  // 🟢 数据映射层：关键业务字段（从 dataJson 中提取，用于 SQL 统计查询）
  riskLevel      String? // 风险等级：low, medium, high, critical
  workType       String? // 作业类型：动火、高处、受限空间等
  location       String? // 作业地点
  applicantId    String? // 申请人ID
  applicantName  String? // 申请人姓名
  // ⚠️ DEPRECATED: 使用 applicantDeptName 替代
  applicantDept  String? // 申请人部门
  // ✅ 新字段：申请人部门名称（推荐使用）
  applicantDeptName String? // 申请人部门名称
  workDate       DateTime? // 作业日期
  workStartTime  DateTime? // 作业开始时间
  workEndTime    DateTime? // 作业结束时间
  supervisorId   String? // 监护人ID
  supervisorName String? // 监护人姓名

  // 关联关系
  signatures SignatureRecord[]
  subPermits SubPermit[]

  // 索引：用于统计查询
  @@index([riskLevel])
  @@index([workType])
  @@index([location])
  @@index([applicantId])
  @@index([applicantDept])
  @@index([workDate])
  @@index([status])
  @@index([createdAt])
  @@index([workType, workDate]) // 复合索引：按类型和日期统计
  @@index([applicantDept, workDate]) // 复合索引：按部门和日期统计
}

model User {
  id                  String                  @id @default(cuid())
  username            String                  @unique
  name                String
  password            String
  avatar              String                  @default("/image/default_avatar.jpg")
  role                String                  @default("user")
  departmentId        String?
  department          Department?             @relation(fields: [departmentId], references: [id])
  jobTitle            String?
  directManagerId     String?
  permissions         String?
  isActive            Boolean                 @default(true) // 在职状态：true=在职，false=离职
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  reportedHazards     HazardRecord[]          @relation("Reporter")
  assignedHazards     HazardRecord[]          @relation("Responsible")
  uploadedMaterials   TrainingMaterial[]
  publishedTasks      TrainingTask[]          @relation("TaskPublisher")
  trainingAssignments TrainingAssignment[]
  learnedRecords      MaterialLearnedRecord[]
  uploadedFiles       FileMetadata[]          @relation("FileUploader")
  reportedIncidents   Incident[]              @relation("IncidentReporter")
}

model Department {
  id        String       @id @default(cuid())
  name      String
  parentId  String?
  parent    Department?  @relation("DeptHierarchy", fields: [parentId], references: [id])
  children  Department[] @relation("DeptHierarchy")
  managerId String?
  level     Int          @default(1)
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  users     User[]
  incidents Incident[]   @relation("IncidentDepartment")
}

model HazardRecord {
  id                      String    @id @default(cuid())
  code                    String?   @unique
  status                  String    @default("reported")
  riskLevel               String    @default("low")
  checkType               String    @default("daily") // 检查类型：daily, special, monthly, pre-holiday, self, other
  rectificationType       String    @default("scheduled") // 整改方式：immediate, scheduled
  type                    String
  location                String
  desc                    String
  photos                  String?
  reporterId              String
  reporter                User      @relation("Reporter", fields: [reporterId], references: [id])
  reporterName            String
  reporterDeptName        String? // 上报人部门名称（快照）
  reportTime              DateTime  @default(now())

  // ============ 整改责任人信息 ============
  // ⚠️ DEPRECATED: 使用 rectificationLeaderId 替代
  responsibleId           String?
  responsible             User?     @relation("Responsible", fields: [responsibleId], references: [id])
  // ⚠️ DEPRECATED: 使用 rectificationLeaderName 替代
  responsibleName         String?
  // ⚠️ DEPRECATED: 已废弃，勿使用
  responsibleDept         String?

  // ✅ 新字段：整改责任人（推荐使用）
  rectificationLeaderId   String? // 整改责任人ID
  rectificationLeaderName String? // 整改责任人姓名
  rectificationDeptId     String? // 整改部门ID
  rectificationDeptName   String? // 整改部门名称

  deadline                DateTime?

  // ============ 整改过程信息 ============
  // ⚠️ DEPRECATED: 使用 rectificationNotes 替代
  rectifyDesc             String?
  // ⚠️ DEPRECATED: 使用 rectificationPhotos 替代
  rectifyPhotos           String?
  // ⚠️ DEPRECATED: 使用 rectificationTime 替代
  rectifyTime             DateTime?
  // ⚠️ DEPRECATED: 使用 rectificationRequirements 替代
  rectifyRequirement      String?

  // ✅ 新字段：整改过程（推荐使用）
  rectificationNotes      String? // 整改备注
  rectificationPhotos     String? // 整改照片（JSON数组）
  rectificationTime       DateTime? // 整改完成时间
  rectificationRequirements String? // 整改要求

  // ============ 验收信息 ============
  verifierId              String?
  verifierName            String?

  // ⚠️ DEPRECATED: 使用 verificationTime 替代
  verifyTime              DateTime?
  // ⚠️ DEPRECATED: 使用 verificationPhotos 替代
  verifyPhotos            String? // 验收时的现场照片路径（JSON字符串）
  // ⚠️ DEPRECATED: 使用 verificationNotes 替代
  verifyDesc              String? // 验收时的描述/评价

  // ✅ 新字段：验收过程（推荐使用）
  verificationTime        DateTime? // 验收时间
  verificationPhotos      String? // 验收照片（JSON数组）
  verificationNotes       String? // 验收意见

  // ============ 应急预案相关 ============
  requireEmergencyPlan    Boolean   @default(false)
  emergencyPlanDeadline   DateTime?
  emergencyPlanContent    String?
  emergencyPlanSubmitTime DateTime?

  // ============ 根因分析 ============
  rootCause               String? // 根本原因分析分类（如：人的不安全行为、物的不安全状态、管理缺陷等）

  // ============ 抄送信息 ============
  // ⚠️ DEPRECATED: 使用 ccDeptIds 替代
  ccDepts                 String?
  // ⚠️ DEPRECATED: 使用 ccUserIds 替代
  ccUsers                 String?

  // ✅ 新字段：抄送（推荐使用）
  ccDeptIds               String? // 抄送部门ID列表（JSON数组）
  ccUserIds               String? // 抄送用户ID列表（JSON数组）

  // ============ 工作流执行人信息 ============
  logs                    String?

  // ⚠️ DEPRECATED: 使用 historicalHandlerIds 替代
  old_personal_ID         String?
  // ⚠️ DEPRECATED: 使用 currentExecutorId 替代（极差命名）
  dopersonal_ID           String? // 当前步骤执行人ID（动态字段，随步骤流转更新）
  // ⚠️ DEPRECATED: 使用 currentExecutorName 替代（极差命名）
  dopersonal_Name         String? // 当前步骤执行人姓名（动态字段，随步骤流转更新）

  // ✅ 新字段：当前执行人（推荐使用）
  currentExecutorId       String? // 当前步骤执行人ID
  currentExecutorName     String? // 当前步骤执行人姓名
  historicalHandlerIds    String? // 历史处理人ID列表（JSON数组）

  candidateHandlers       String? // 🟢 或签/会签模式：候选处理人列表（JSON格式）
  approvalMode            String? // 🟢 当前步骤的审批模式（OR=或签，AND=会签）
  currentStepIndex        Int?      @default(0) // 当前步骤索引（用于追踪工作流位置）
  currentStepId           String? // 当前步骤ID（用于追踪工作流位置）

  // 🟢 软删除字段（用于审计和恢复）
  isVoided                Boolean   @default(false) // 是否已作废
  voidReason              String? // 作废原因
  voidedAt                DateTime? // 作废时间
  voidedBy                String? // 作废操作人信息（JSON格式：{id, name, role}）

  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  // 关联关系
  signatures SignatureRecord[]
  extensions HazardExtension[]
  candidateHandlersRel HazardCandidateHandler[] // 🟢 或签/会签候选处理人关联表
  ccUsersRel HazardCC[] // 🟢 抄送用户关联表
  workflowStepsRel HazardWorkflowStep[] // 🟢 工作流步骤关联表（存储每个步骤的执行人和抄送人）
  visibilityRecords HazardVisibility[] // 🚀 可见性记录（Row-Level Security）

  // 🟢 索引优化
  @@index([isVoided])
  @@index([voidedAt])
}

// 隐患整改延期历史记录
model HazardExtension {
  id          String       @id @default(cuid())
  hazardId    String
  hazard      HazardRecord @relation(fields: [hazardId], references: [id], onDelete: Cascade)
  oldDeadline DateTime // 原定截止日期
  newDeadline DateTime // 申请的新截止日期
  reason      String // 延期原因
  applicantId String // 申请人ID
  approverId  String? // 批准人ID（Nullable）
  status      String       @default("pending") // 状态：pending(待审批), approved(已批准), rejected(已驳回)
  createdAt   DateTime     @default(now())

  // 索引
  @@index([hazardId])
  @@index([applicantId])
  @@index([approverId])
  @@index([status])
  @@index([createdAt])
}

// 🟢 隐患编号池（用于编号回收利用）
// 用途：当隐患被软删除（作废）时，将编号释放到此池中，供后续创建隐患时重用
// 优势：保持编号连续性，避免编号浪费，便于审计追溯
model HazardCodePool {
  id         String    @id @default(cuid())
  code       String    @unique // 被释放的编号（如：Hazard20250202001）
  datePrefix String // 日期前缀（如：20250202），用于快速筛选当天可用编号
  sequence   Int // 序号（如：1, 2, 3），用于排序，优先重用小序号
  status     String    @default("available") // available(可用), used(已使用), expired(过期)
  releasedBy String? // 释放此编号的操作人ID
  releasedAt DateTime  @default(now()) // 释放时间
  usedAt     DateTime? // 被重新使用的时间
  usedBy     String? // 重新使用此编号的操作人ID
  expiresAt  DateTime? // 过期时间（可选：如30天后过期，避免编号池过大）
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // 🔥 性能关键索引
  @@index([status]) // 按状态筛选
  @@index([datePrefix, status]) // 复合索引：查询某天的可用编号（核心查询）
  @@index([datePrefix, sequence]) // 复合索引：按日期和序号排序，保证编号连续性
  @@index([expiresAt]) // 用于定时清理过期编号
}

// 🟢 隐患候选处理人关联表（用于或签/会签模式，持久化操作状态）
model HazardCandidateHandler {
  id          String       @id @default(cuid())
  hazardId    String
  hazard      HazardRecord @relation(fields: [hazardId], references: [id], onDelete: Cascade)
  userId      String // 候选处理人ID
  userName    String // 候选处理人姓名（快照）
  stepIndex   Int // 步骤索引（用于区分不同步骤的候选处理人）
  stepId      String? // 步骤ID
  hasOperated Boolean      @default(false) // 是否已操作
  operatedAt  DateTime? // 操作时间
  opinion     String? // 操作意见（如：同意、驳回等）
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // 索引
  @@unique([hazardId, userId, stepIndex]) // 确保同一隐患、同一用户、同一步骤只有一条记录
  @@index([hazardId])
  @@index([userId])
  @@index([stepIndex])
  @@index([hasOperated])
  @@index([hazardId, stepIndex]) // 复合索引：查询某隐患某步骤的所有候选处理人
  @@index([userId, hasOperated]) // 复合索引：查询某用户待处理的任务
}

// 🟢 隐患抄送用户关联表（规范化抄送关系，提升查询性能）
model HazardCC {
  id        String       @id @default(cuid())
  hazardId  String
  hazard    HazardRecord @relation(fields: [hazardId], references: [id], onDelete: Cascade)
  userId    String // 抄送用户ID
  userName  String? // 抄送用户姓名（快照，可选）
  createdAt DateTime     @default(now())

  // 索引
  @@unique([hazardId, userId]) // 确保同一隐患、同一用户只有一条记录
  @@index([hazardId])
  @@index([userId])
  @@index([hazardId, userId]) // 复合索引：查询某隐患的抄送用户
}

// 🟢 隐患工作流步骤表（存储每个隐患的每个步骤的执行人和抄送人信息）
// 用途：在创建隐患时，通过 HazardHandlerResolverService 解析所有步骤并保存，后续操作从数据库读取
model HazardWorkflowStep {
  id              String       @id @default(cuid())
  hazardId        String       // 隐患ID
  hazard          HazardRecord @relation(fields: [hazardId], references: [id], onDelete: Cascade)
  stepIndex       Int          // 步骤索引（0, 1, 2...）
  stepId          String       // 步骤ID（如：report, assign, rectify, verify）
  stepName        String       // 步骤名称（如：上报并指派、指派整改、提交整改、验收闭环）
  handlerUserIds  String       // 执行人ID列表（JSON数组）
  handlerUserNames String      // 执行人姓名列表（JSON数组）
  matchedBy       String?      // 匹配策略（如：fixed, department_manager等）
  ccUserIds       String?      // 抄送人ID列表（JSON数组）
  ccUserNames     String?      // 抄送人姓名列表（JSON数组）
  approvalMode    String?      // 审批模式（OR=或签，AND=会签）
  success         Boolean      @default(true) // 是否成功匹配
  error            String?     // 匹配失败时的错误信息
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // 索引
  @@unique([hazardId, stepIndex]) // 确保同一隐患、同一步骤只有一条记录
  @@index([hazardId])
  @@index([stepIndex])
  @@index([hazardId, stepIndex]) // 复合索引：查询某隐患的某步骤
}

// 🚀 隐患可见性表（Row-Level Security 性能优化方案）
// 用途：扁平化权限关系，将"谁可以看到哪些隐患"预计算并存储，避免复杂的 JOIN 查询
// 适用场景：百万级数据量下，实现高性能的"我的隐患"查询
model HazardVisibility {
  id        String       @id @default(cuid())
  hazardId  String       // 隐患ID
  hazard    HazardRecord @relation(fields: [hazardId], references: [id], onDelete: Cascade)
  userId    String       // 可见用户ID
  role      String       // 用户在该隐患中的角色：creator, executor, cc, responsible, verifier, candidate
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // 🔥 性能关键索引（P0修复：调整索引顺序）
  @@unique([userId, hazardId, role]) // ✅ 修复：userId在前，匹配查询模式
  @@index([userId, hazardId]) // 🚀 核心索引：查询某用户可见的所有隐患（覆盖索引）
  @@index([hazardId]) // 查询某隐患的所有可见用户
  @@index([role]) // 按角色筛选
  @@index([userId, role]) // 查询某用户以某角色可见的隐患
}

model HazardConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============ 事故事件管理模块 ============
model Incident {
  id   String  @id @default(cuid())
  code String? @unique // 事故编号，如：INC-2024-001

  // ============ 基础信息 ============
  type        String // 事故类型：injury(伤害事故), near_miss(未遂事故), property_damage(财产损失), environmental(环境事故)
  severity    String // 严重程度：minor(轻微), moderate(中等), serious(严重), critical(重大)
  occurredAt  DateTime // 事故发生时间
  location    String // 发生地点
  description String // 事故描述

  // ============ 关联关系 ============
  reporterId       String // 上报人ID
  reporter         User     @relation("IncidentReporter", fields: [reporterId], references: [id])
  reporterName     String // 上报人姓名（快照）
  // ⚠️ DEPRECATED: 使用 reporterDeptName 替代
  reporterDept     String? // 上报人部门（快照）
  reporterDeptName String? // ✅ 上报人部门名称（推荐使用）
  reportTime       DateTime @default(now()) // 上报时间

  departmentId   String? // 责任部门ID
  department     Department? @relation("IncidentDepartment", fields: [departmentId], references: [id])
  departmentName String? // 责任部门名称（快照）

  // ============ 调查详情（5Why分析法） ============
  // 直接原因
  directCause String? // 直接原因描述

  // 间接原因
  indirectCause String? // 间接原因描述

  // 管理原因
  managementCause String? // 管理原因描述

  // 根本原因（综合）
  rootCause String? // 根本原因分析

  // ============ 整改措施 (CAPA) ============
  correctiveActions         String? // 纠正措施（JSON格式，支持多条）
  preventiveActions         String? // 预防措施（JSON格式，支持多条）
  actionDeadline            DateTime? // 整改措施完成期限
  // ⚠️ DEPRECATED: 使用 rectificationLeaderId 替代
  actionResponsibleId       String? // 整改措施负责人ID
  // ⚠️ DEPRECATED: 使用 rectificationLeaderName 替代
  actionResponsibleName     String? // 整改措施负责人姓名
  // ✅ 新字段：整改责任人（推荐使用，与 HazardRecord 统一）
  rectificationLeaderId     String? // 整改责任人ID
  rectificationLeaderName   String? // 整改责任人姓名

  // ============ 附件与证据 ============
  photos              String? // 现场照片（JSON数组，存储MinIO路径）
  attachments         String? // 其他附件（JSON数组，存储MinIO路径）
  investigationReport String? // 调查报告（MinIO路径）

  // ============ 工作流集成 ============
  status           String  @default("reported") // 状态：reported(已上报), investigating(调查中), reviewed(待审批), closed(已结案), rejected(已驳回)
  currentStepIndex Int?    @default(0) // 当前工作流步骤索引
  currentStepId    String? // 当前工作流步骤ID
  flowId           String? // 关联的工作流定义ID
  workflowLogs     String? // 工作流审批日志（JSON格式）

  // 当前处理人（动态字段，随工作流流转更新）
  currentHandlerId   String?
  currentHandlerName String?
  candidateHandlers  String? // 候选处理人列表（JSON格式，用于或签/会签）
  approvalMode       String? // 当前步骤的审批模式（OR=或签，AND=会签）

  // ============ 审批与结案 ============
  reviewerId    String? // 审批人ID
  reviewerName  String? // 审批人姓名
  reviewTime    DateTime? // 审批时间
  reviewComment String? // 审批意见

  closerId    String? // 结案人ID
  closerName  String? // 结案人姓名
  closeTime   DateTime? // 结案时间
  closeReason String? // 结案原因

  // ============ 数字签名 ============
  signatures SignatureRecord[] // 关联的签名记录（调查报告签字、结案签字等）

  // ============ 通知与抄送 ============
  // ⚠️ DEPRECATED: 使用 ccDeptIds 替代
  ccDepts   String? // 抄送部门（JSON数组）
  // ⚠️ DEPRECATED: 使用 ccUserIds 替代
  ccUsers   String? // 抄送用户（JSON数组）
  // ✅ 新字段：抄送（推荐使用）
  ccDeptIds String? // 抄送部门ID列表（JSON数组）
  ccUserIds String? // 抄送用户ID列表（JSON数组）

  // ============ 时间戳 ============
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ============ 索引优化 ============
  @@index([type])
  @@index([severity])
  @@index([status])
  @@index([reporterId])
  @@index([departmentId])
  @@index([occurredAt])
  @@index([createdAt])
  @@index([status, occurredAt]) // 复合索引：按状态和时间查询
  @@index([departmentId, occurredAt]) // 复合索引：按部门和时间统计
}

model Document {
  id         String     @id @default(cuid())
  name       String
  type       String
  docxPath   String?
  pdfPath    String?
  prefix     String?
  suffix     Int?
  fullNum    String?
  level      Int
  parentId   String?
  parent     Document?  @relation("DocHierarchy", fields: [parentId], references: [id])
  children   Document[] @relation("DocHierarchy")
  dept       String?
  // ⚠️ DEPRECATED: 使用 uploaderName 和 uploaderId 替代
  uploader   String? // 上传者用户名（不推荐，应使用 uploaderId）
  // ⚠️ DEPRECATED: 使用 uploadedAt 替代
  uploadTime DateTime   @default(now())
  // ✅ 新字段：上传者信息（推荐使用）
  uploaderId   String? // 上传者ID
  uploaderName String? // 上传者姓名
  uploadedAt   DateTime? // 上传时间
  version    String    @default("1.0") // 文档版本号
  searchText String?

  // 🟢 EHS Archive Fields
  archiveCategory String? // 'enterprise', 'equipment', 'personnel'
  expiryDate      DateTime? // License/Certificate expiration date
  warningDays     Int       @default(30) // Days before expiry to warn
  entityId        String? // Link to User.id or Equipment ID

  tags Tag[] @relation("DocumentTags")

  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  history   DocumentHistory[]

  @@index([archiveCategory, expiryDate]) // 按分类查到期证照；单加 expiryDate 扫描范围过宽
}

model Tag {
  id        String     @id @default(cuid())
  name      String     @unique
  color     String     @default("#blue") // UI display color
  documents Document[] @relation("DocumentTags")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model DocumentHistory {
  id           String   @id @default(cuid())
  documentId   String
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  type         String // 'docx', 'xlsx', 'pdf'
  name         String
  path         String
  uploader     String?
  uploadTime   DateTime @default(now())
  revisionDate String?  // 修订日期（取自 createdAt 的年月日，格式 YYYY-MM-DD）
  version      String?  // 归档时的文档版本号
  createdAt    DateTime @default(now())
}

model SystemLog {
  id String @id @default(cuid())

  // ============ 操作人身份信息（快照） ============
  userId           String?
  userName         String?
  userRole         String? // 操作时的系统角色（admin/user/manager等）
  userDepartment   String? // 操作时所属部门名称
  userDepartmentId String? // 操作时所属部门ID
  userJobTitle     String? // 操作时的职位
  userRoleInAction String? // 用户在本次操作中的业务角色（上报人/整改人/验收人/审批人等）

  // ============ 操作信息 ============
  module       String // 所属模块：HAZARD, WORK_PERMIT, TRAINING, USER, ORG, SYSTEM 等
  action       String // 操作类型：CREATE, UPDATE, DELETE, APPROVE, REJECT, EXPORT, LOGIN 等
  actionLabel  String? // 操作类型的中文描述（自动生成，如："创建隐患"、"审批作业票"）
  businessCode String? // 标准业务编码（如：HD_CRT_001, WP_APV_001），遵循业务编号规范

  // ============ 操作对象 ============
  targetId    String? // 被操作的业务实体编号（如：HZ-2024-001, JOB-2024-001）⚠️ 使用业务编号，非数据库ID
  targetType  String? // 操作对象类型（hazard, document, permit, training_task, user 等）
  targetLabel String? // 被操作对象的描述（如：隐患简述前50字、文档标题、作业类型）
  targetLink  String? // 🔗 操作对象的详情页链接（用于日志追溯跳转）

  // ============ 审计细节（核心） ============
  snapshot   String? // 📸 操作后的完整对象快照（JSON），清洗敏感字段后存储，用于完整还原当时的状态
  diff       String? // 📊 修改前后的差异对比（JSON），格式：{ fieldName: { old: value, new: value } }
  changes    String? // ⚠️ 保留字段，向下兼容，优先使用 diff
  beforeData String? // ⚠️ 保留字段，向下兼容，新系统使用 snapshot 和 diff
  afterData  String? // ⚠️ 保留字段，向下兼容，新系统使用 snapshot 和 diff

  // ============ 客户端环境信息 ============
  clientInfo String? // 📱 客户端环境信息（JSON），包含：{ ip, userAgent, device, browser, os }
  ip         String? // ⚠️ 保留字段，向下兼容，新系统存入 clientInfo
  userAgent  String? // ⚠️ 保留字段，向下兼容，新系统存入 clientInfo

  // ============ 其他信息 ============
  details String? // 操作的自然语言描述（如："张三 审批通过了 作业票 [JOB-2024-001]"）

  createdAt DateTime @default(now())

  // ============ 性能优化索引 ============
  @@index([userId]) // 按用户查询
  @@index([module]) // 按模块查询
  @@index([action]) // 按操作类型查询
  @@index([targetType]) // 按对象类型查询
  @@index([targetId]) // 按业务编号查询（高频）
  @@index([businessCode]) // 按业务编码查询
  @@index([createdAt]) // 按时间排序
  @@index([module, targetId]) // 复合查询：某模块下的某个对象的全生命周期日志
  @@index([userId, createdAt]) // 复合查询：某用户的操作时间线
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  content     String
  relatedType String?
  relatedId   String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TrainingMaterial {
  id                  String                  @id @default(cuid())
  title               String
  description         String?
  type                String // video, pdf, docx
  category            String? // 学习类型分类
  url                 String
  convertedUrl        String? // PDF version of docx
  thumbnail           String? // 缩略图路径
  thumbnailPendingSince DateTime? // 缩略图开始生成的时间戳，用于检测僵尸锁
  duration            Int? // seconds, for video
  isExamRequired      Boolean                 @default(false)
  passingScore        Int?
  examMode            String                  @default("standard") // standard, random
  randomQuestionCount Int? // 随机模式下的题目数量
  isPublic            Boolean                 @default(true) // 是否放入公共知识库
  uploaderId          String
  uploader            User                    @relation(fields: [uploaderId], references: [id])
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  questions           ExamQuestion[]
  tasks               TrainingTask[]
  learnedRecords      MaterialLearnedRecord[]
}

model ExamQuestion {
  id         String           @id @default(cuid())
  materialId String
  material   TrainingMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)
  type       String // single, multiple
  question   String
  options    String // JSON string
  answer     String // JSON string
  score      Int
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
}

model TrainingTask {
  id              String               @id @default(cuid())
  title           String
  description     String?
  startDate       DateTime
  endDate         DateTime
  materialId      String
  material        TrainingMaterial     @relation(fields: [materialId], references: [id])
  publisherId     String
  publisher       User                 @relation("TaskPublisher", fields: [publisherId], references: [id])
  targetType      String // all, dept, user
  targetConfig    String? // JSON string
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  assignments     TrainingAssignment[]
  autoAssignRules AutoAssignRule[]
}

// 自动派发规则：用于把培训任务与事件/规则绑定
model AutoAssignRule {
  id        String       @id @default(cuid())
  taskId    String
  task      TrainingTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  mode      String // 'event' | 'rule'
  eventType String? // 例如: 'user_first_login','job_changed','document_updated','exam_finished'
  condition String? // 存储触发条件与目标配置的 JSON 字符串，例如 { jobTitle: '操作工' } 或 { documentId: '...' }
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model TrainingAssignment {
  id          String       @id @default(cuid())
  taskId      String
  task        TrainingTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  status      String // assigned, in-progress, completed, passed, failed
  progress    Int // 0-100 or seconds watched
  isPassed    Boolean      @default(false)
  examScore   Int?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([taskId, userId])
}

model MaterialLearnedRecord {
  id         String           @id @default(cuid())
  materialId String
  material   TrainingMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  learnedAt  DateTime         @default(now())

  @@unique([materialId, userId])
}

// 通知模板管理
model NotificationTemplate {
  id               String   @id @default(cuid())
  name             String   @unique
  title            String // 支持变量占位符，如 {{user.name}}
  content          String // 支持变量占位符
  type             String // hazard, training, work_permit, system
  triggerEvent     String // 触发事件：hazard_created, hazard_assigned, etc
  triggerCondition String? // JSON配置：条件规则
  isActive         Boolean  @default(true)
  variables        String? // JSON数组：可用变量列表
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// AI API 配置
model AIApiConfig {
  id                 String     @id @default(cuid())
  name               String     @unique
  provider           String // openai, azure, custom
  apiKey             String // 加密存储
  endpoint           String
  model              String? // gpt-4, gpt-3.5-turbo, etc
  maxTokens          Int        @default(2000)
  temperature        Float      @default(0.7)
  isActive           Boolean    @default(true)
  rateLimitPerMinute Int        @default(1000) // 限流策略：每分钟最大调用次数
  rateLimitPerDay    Int        @default(50000) // 每天最大调用次数
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  logs               AIApiLog[]
}

// AI API 调用日志
model AIApiLog {
  id              String      @id @default(cuid())
  configId        String
  config          AIApiConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  requestBy       String? // 调用者用户ID或系统名称
  requestSource   String? // hazard, training, work_permit, custom
  requestPayload  String? // JSON：请求内容
  responsePayload String? // JSON：响应内容
  tokens          Int? // 消耗的token数
  duration        Int? // 响应时间（毫秒）
  status          String // success, error, rate_limited
  errorMessage    String?
  ip              String?
  createdAt       DateTime    @default(now())
}

// AI API 用户限流策略
model AIApiRateLimit {
  id           String   @id @default(cuid())
  userId       String? // 用户ID，如果为null则应用于所有用户
  departmentId String? // 部门ID，如果为null则应用于所有部门
  dailyLimit   Int      @default(100) // 每日API调用总次数限制
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, departmentId], name: "userId_departmentId") // 确保每个用户/部门组合只有一个限流策略
  @@index([userId])
  @@index([departmentId])
}

// 文件元数据表 - 用于文件索引和增量备份
model FileMetadata {
  id             String    @id @default(cuid())
  filePath       String    @unique // 文件相对路径，如 /uploads/docs/DOCX-xxx.docx
  fileName       String // 原始文件名
  fileType       String // docx, pdf, xlsx, mp4, jpg, png等
  fileSize       Int // 文件大小（字节）
  md5Hash        String    @unique // MD5哈希值，用于去重和增量备份
  category       String // docs, training, avatar, thumbnail, other
  uploaderId     String?
  uploader       User?     @relation("FileUploader", fields: [uploaderId], references: [id])
  uploadedAt     DateTime  @default(now())
  lastAccessedAt DateTime? // 最后访问时间，用于归档策略
  isArchived     Boolean   @default(false) // 是否已归档到冷存储
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([md5Hash])
  @@index([category])
  @@index([uploadedAt])
  @@index([lastAccessedAt])
  @@index([isArchived])
}

// 🟢 电子签名记录表（符合审计要求的电子签名方案）
model SignatureRecord {
  id         String            @id @default(cuid())
  permitId   String?
  permit     WorkPermitRecord? @relation(fields: [permitId], references: [id], onDelete: Cascade)
  incidentId String?
  incident   Incident?         @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  hazardId   String?
  hazard     HazardRecord?     @relation(fields: [hazardId], references: [id], onDelete: Cascade)
  signerId   String // 签字人ID
  signerName String // 签字人姓名
  action     String // 'pass' | 'reject' | 'issue' | 'site_confirm' | 'investigate' | 'close'
  comment    String? // 审批意见
  stepIndex  Int // 审批步骤索引
  stepName   String? // 审批步骤名称

  // 🔐 防篡改核心字段
  dataSnapshotHash String // 签字时刻表单数据的 Hash 值（SHA-256）
  dataSnapshot     String? // 签字时刻表单数据的完整快照（JSON，可选，用于审计）

  // 时间戳
  signedAt DateTime @default(now())

  // 客户端环境信息（用于审计）
  clientInfo String? // JSON：{ ip, userAgent, device, browser, os }

  // 索引
  @@index([permitId])
  @@index([incidentId])
  @@index([hazardId])
  @@index([signerId])
  @@index([signedAt])
  @@index([action])
  @@index([permitId, stepIndex]) // 复合索引：查询某个作业票的某个步骤的所有签名
  @@index([incidentId, stepIndex]) // 复合索引：查询某个事故的某个步骤的所有签名
  @@index([hazardId, stepIndex]) // 复合索引：查询某个隐患的某个步骤的所有签名
}

// 🟢 子表单表（解耦二级表单数据）
model SubPermit {
  id             String           @id @default(cuid())
  parentPermitId String
  parentPermit   WorkPermitRecord @relation(fields: [parentPermitId], references: [id], onDelete: Cascade)
  templateId     String // 绑定的二级模板ID
  code           String? // 子表单编号（如：父编号-字段名简写）
  cellKey        String // 父表单中绑定的单元格键（如：R5C3）
  fieldName      String? // 字段名（用于生成编号）
  dataJson       String // 子表单的完整数据（JSON）

  // 状态（可选，用于子表单的独立审批流程）
  status       String  @default("draft")
  currentStep  Int     @default(0)
  approvalLogs String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 索引
  @@index([parentPermitId])
  @@index([templateId])
  @@index([code])
  @@index([cellKey])
  @@index([status])
  @@index([createdAt])
}

// ============ EHS 档案库系统 ============

// 设备档案
model Equipment {
  id              String        @id @default(cuid())
  name            String // 设备名称
  code            String        @unique // 设备编号
  description     String? // 设备描述
  startDate       DateTime // 启用日期
  expectedEndDate DateTime? // 预计报废日期
  isSpecialEquip  Boolean       @default(false) // 是否特种设备
  inspectionCycle Int? // 定检周期（月）
  lastInspection  DateTime? // 上次定检日期
  nextInspection  DateTime? // 下次定检日期
  status          String        @default("active") // active, disposed, under_maintenance
  files           ArchiveFile[] @relation("EquipmentFiles")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@index([isSpecialEquip])
  @@index([nextInspection])
}

// 档案文件（通用）
model ArchiveFile {
  id           String  @id @default(cuid())
  name         String // 显示名称
  fileType     String // 文件类型分类（从配置库选择）
  isDynamic    Boolean @default(false) // 静态/动态资料
  description  String? // 文件描述
  filePath     String // MinIO 存储路径（格式：bucket:key）
  originalName String // 原始文件名
  mimeType     String // MIME 类型
  fileSize     Int // 文件大小（字节）

  // 关联分类（四选一）
  category    String // 'enterprise' | 'equipment' | 'personnel' | 'msds'
  equipmentId String?
  equipment   Equipment? @relation("EquipmentFiles", fields: [equipmentId], references: [id], onDelete: Cascade)
  userId      String? // 关联 User.id（一人一档）

  uploaderId   String? // 上传者ID
  uploaderName String? // 上传者姓名
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
  @@index([equipmentId])
  @@index([userId])
  @@index([fileType])
  @@index([createdAt])
}

// 档案系统配置
model ArchiveConfig {
  id        String   @id @default(cuid())
  key       String   @unique // watermark, enterprise_types, equipment_types, personnel_types
  value     String // JSON 格式存储
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 检查类型配置表
model CheckType {
  id          String   @id @default(cuid())
  name        String // 显示名称，如："日常检查"
  value       String   @unique // 值，如："daily"
  description String? // 描述
  sortOrder   Int      @default(0) // 排序
  isActive    Boolean  @default(true) // 是否启用
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
}

// 文件删除队列 - 用于跟踪 MinIO 删除失败的文件，支持重试
model FileDeletionQueue {
  id          String   @id @default(cuid())
  filePath    String   // 数据库记录格式，如 "public:docs/xxx.pdf"
  bucket      String   // MinIO bucket 名称
  objectName  String   // MinIO 对象键
  status      String   @default("pending") // pending, retrying, failed, completed
  retryCount  Int      @default(0)
  lastTriedAt DateTime?
  errorMsg    String?  // 最后一次尝试的错误信息
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([lastTriedAt])
}

// 人员职业健康档案
model PersonnelHealthRecord {
  id                  String    @id @default(cuid())
  userId              String    @unique
  hazardFactors       String?   // 危险有害因素
  requirePeriodicExam Boolean   @default(false) // 是否需要定期职业健康体检
  lastExamDate        DateTime? // 上次职业健康体检时间
  examCycle           Int?      // 职业健康体检周期（年：1/2/3）
  nextExamDate        DateTime? // 下次职业健康体检日期（自动计算）
  lastExamReminderAt  DateTime? // 最近一次发送体检提醒的时间（防重复通知用）
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([userId])
  @@index([requirePeriodicExam, nextExamDate]) // 每日扫描核心复合索引
}

// ============ 注意事项 ============
// SQLite 不支持原生枚举类型，因此 module 和 action 字段使用 String 类型
// 类型安全由 TypeScript 枚举（src/types/audit.ts）在应用层保证
