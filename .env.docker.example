# ============================================
# EHS 系统 Docker 生产环境配置示例
# ============================================
#
# 使用说明：
# 1. 复制此文件为 .env.docker.local
#    cp .env.docker.example .env.docker.local
#
# 2. 根据实际部署环境修改配置
#
# 3. ⚠️ 特别注意：MINIO_ENDPOINT 必须是浏览器可访问的地址
#
# ============================================

# 应用端口（宿主机映射端口）
APP_PORT=3000

# 数据库配置（容器内路径，会挂载到宿主机 ./data 目录）
DATABASE_URL=file:/app/data/db/ehs.db

# ============================================
# MinIO 配置 - 关键配置项
# ============================================
#
# ⚠️ 重要：MINIO_ENDPOINT 必须填写浏览器可访问的地址
#
# 场景 1：本机部署（仅本机访问）
#   MINIO_ENDPOINT=localhost
#   MINIO_PRIMARY_ENDPOINT=http://localhost:9000
#
# 场景 2：局域网部署（局域网内访问）
#   MINIO_ENDPOINT=192.168.1.100  # 替换为服务器的局域网 IP
#   MINIO_PRIMARY_ENDPOINT=http://192.168.1.100:9000
#
# 场景 3：公网部署（使用域名）
#   MINIO_ENDPOINT=minio.yourdomain.com
#   MINIO_PRIMARY_ENDPOINT=https://minio.yourdomain.com
#   MINIO_USE_SSL=true
#
# ⚠️ 错误示例：不要使用容器名称
#   MINIO_ENDPOINT=minio  # ❌ 浏览器无法访问容器内部 DNS
#
# ============================================

# MinIO 端点（⚠️ 必须修改为实际可访问的 IP 或域名）
MINIO_ENDPOINT=localhost

# MinIO 端口
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# MinIO SSL 配置
MINIO_USE_SSL=false

# MinIO 访问凭证（⚠️ 生产环境请修改为强密码）
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=change-me-to-strong-password

# MinIO Root 凭证（⚠️ 生产环境请修改为强密码）
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=change-me-to-strong-password

# MinIO 主端点（完整 URL，必须与 MINIO_ENDPOINT 一致）
MINIO_PRIMARY_ENDPOINT=http://localhost:9000

# MinIO 主端点访问凭证（与上面保持一致）
MINIO_PRIMARY_ACCESS_KEY=admin
MINIO_PRIMARY_SECRET_KEY=change-me-to-strong-password

# MinIO 备份目标路径（容器内路径，挂载到上层 data 目录）
MINIO_BACKUP_TARGET=/app/data/minio-backup

# ============================================
# Restic 备份配置
# ============================================

# Restic 仓库路径（容器内路径，挂载到上层 data 目录）
RESTIC_REPOSITORY=/app/data/restic-repo

# Restic 密码（⚠️ 生产环境请修改为强密码）
RESTIC_PASSWORD=change-me-to-strong-password

# Restic 连接 MinIO 的配置（容器内使用服务名）
RESTIC_MINIO_ENDPOINT=http://minio:9000
RESTIC_MINIO_BUCKET=restic-backup
